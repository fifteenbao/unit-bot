# 环境变量（包含 API Key 等敏感信息）
.env

# 用户数据源配置（含私有飞书链接 / 本地路径）
config.yaml

# 私有拆机数据（Excel / CSV / 原始数据）
data/*.xlsx
data/*.xls
data/*.csv

# 运行时数据库（本地产品库 & 标准件库，含私有拆机数据）
data/products_db.json
data/components_lib.json
data/components_lib.csv
data/product_specs.json
data/产品数据库.csv

# 拆机分析与标准件库（私有数据，不入 git）
data/teardowns/
data/lib/

# 公开数据（入 git）
!data/model_aliases.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# macOS
.DS_Store
