# 环境变量（包含 API Key 等敏感信息）
.env

# 用户数据源配置（含私有飞书链接 / 本地路径）
config.yaml

# 私有拆机数据（Excel / CSV / 原始数据）
data/*.xlsx
data/*.xls
data/*.csv

# 运行时数据库与私有数据（不入 git）
data/products/
data/teardowns/
data/lib/
data/bom/

# 内部项目专用脚本（含机型标识，不入 git）
scripts/seed_*.py
scripts/analyze_*.py

# 旧路径兼容（迁移后保留，防止意外提交）
data/products_db.json
data/components_lib.json
data/product_specs.json
data/产品数据库.csv

# 公开数据（入 git）
!data/lib/model_aliases.json

# 价格变动历史（本地留存，不入 git）
data/lib/price_history.csv

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# macOS
.DS_Store
