# 环境变量（包含 API Key 等敏感信息）
.env

# 用户数据源配置 — config.yaml 现在入 git（只存路径声明，secrets 走环境变量）
# 保留 config.local.yaml 作为本地覆盖入口（不入 git）
config.local.yaml

# 私有拆机数据（Excel / CSV / 原始数据）
data/*.xlsx
data/*.xls
data/*.csv

# 运行时数据库与私有数据（不入 git）
# 注意：data/products/ 下的 model_aliases.json 需公开，因此改用文件级 pattern
# 以便下方 `!data/products/model_aliases.csv` 白名单生效
data/products/*.csv
data/products/*.json
data/teardowns/
data/lib/
data/bom/

# 内部项目专用脚本（含机型标识 / 本地调试，不入 git）
scripts/seed_*.py
scripts/analyze_*.py
scripts/test_local.py

# 本地测试教程（私有，不入 git）
LOCAL_TEST.md

# 旧路径兼容（迁移后保留，防止意外提交）
data/products_db.json
data/product_specs.json
data/产品数据库.csv

# 公开数据（入 git）
!data/products/model_aliases.csv

# 价格变动历史（本地留存，不入 git）
data/lib/price_history.csv

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Claude Code 本地配置
.claude/

# macOS
.DS_Store
